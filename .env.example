# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Session secret (any long random string)
SESSION_SECRET=

# ── ImgBB (cover image uploads) ───────────────────────────────────────────────
# Get a free key at https://api.imgbb.com
IMGBB_API_KEY=

# ── Deployment ────────────────────────────────────────────────────────────────
# "node" for a Node.js server (Render, Railway, VPS, etc.)
# "cloudflare" for Cloudflare Workers (note: file upload to disk won't work)
DEPLOY_TARGET=node
